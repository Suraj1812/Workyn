# Workyn uses PostgreSQL in production and local development.

# Backend
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/workyn
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL=http://localhost:5173
COOKIE_NAME=workyn_token
AI_ANALYSIS_INTERVAL_MS=900000

# Frontend
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
